{
  "cli_default_open_behavior": "new_window",
  "collaboration_panel": {
    "dock": "left"
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "claude-acp": {
      "type": "registry"
    }
  },
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "openrouter",
      "model": "minimax/minimax-m2.5:free",
      "enable_thinking": true,
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "lsp": {
    "vtsls": {
      "settings": {
        "typescript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
        "javascript": {
          "updateImportsOnFileMove": {
            "enabled": "always",
          },
        },
      },
      "enable_lsp_tasks": true,
    },
  },
  "context_servers": {},
  "autoscroll_on_clicks": false,
  "scroll_beyond_last_line": "one_page",
  "sticky_scroll": {
    "enabled": false,
  },
  "toolbar": {
    "quick_actions": false,
    "breadcrumbs": false,
  },
  "diagnostics": {
    "include_warnings": true,
  },
  "git_panel": {
    "dock": "left",
    "sort_by_path": true,
    "tree_view": true,
    "diff_stats": true,
    "button": true,
  },
  "scrollbar": {
    "axes": {
      "vertical": false,
      "horizontal": false,
    },
    "search_results": true,
    "cursors": true,
    "git_diff": true,
  },
  "outline_panel": {
    "dock": "left",
    "git_status": true,
    "indent_guides": {
      "show": "never",
    },
  },
  "indent_guides": {
    "enabled": false,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "git": {
    "disable_git": false,
    "inline_blame": {
      "show_commit_summary": false,
      "enabled": true,
    },
    "git_gutter": "tracked_files",
    "enable_diff": true,
    "enable_status": true,
  },
  "tabs": {
    "file_icons": false,
    "git_status": false,
  },
  "tab_bar": {
    "show_pinned_tabs_in_separate_row": false,
    "show": true,
  },
  "title_bar": {
    "show_branch_name": true,
    "show_user_picture": true,
    "show_menus": false,
    "show_sign_in": true,
  },
  "terminal": {
    "button": true,
  },
  "status_bar": {
    "active_encoding_button": "enabled",
  },
  "inlay_hints": {
    "enabled": false,
  },
  "relative_line_numbers": "enabled",
  "gutter": {
    "line_numbers": true,
  },
  "autosave": "on_focus_change",
  "multi_cursor_modifier": "cmd_or_ctrl",
  "base_keymap": "Cursor",
  "project_panel": {
    "dock": "left",
    "show_diagnostics": "errors",
    "indent_guides": {
      "show": "never",
    },
    "sticky_scroll": false,
    "starts_open": true,
    "entry_spacing": "comfortable",
    "indent_size": 20.0,
    "git_status_indicator": false,
    "diagnostic_badges": false,
    "bold_folder_labels": false,
    "auto_fold_dirs": false,
    "auto_reveal_entries": true,
    "folder_icons": true,
    "file_icons": true,
    "git_status": false,
    "button": true,
    "default_width": 300.0,
  },
  "ui_font_family": "JetBrainsMonoNL Nerd Font",
  "buffer_font_family": "JetBrainsMonoNL Nerd Font",
  "vim_mode": true,
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "theme": {
    "mode": "dark",
    "light": "One Light",
    // "dark": "Catppuccin Mocha (Blur) [Light]",
    "dark": "Catppuccin Mocha",
  },
  "experimental.theme_overrides": {
    "background.appearance": "blurred",
  },
